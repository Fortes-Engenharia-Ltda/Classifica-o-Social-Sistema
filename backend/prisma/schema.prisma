generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id                Int                @id @default(autoincrement())
  nome              String             @db.VarChar(100)
  email             String             @unique @db.VarChar(100)
  dataNascimento    DateTime?          @map("data_nascimento") @db.Date
  senha             String             @db.VarChar(255)
  perfil            String             @db.VarChar(20)
  status            Boolean            @default(true)
  codigoResetSenha  String?            @map("codigo_reset_senha") @db.VarChar(10)
  expiraResetSenha  DateTime?          @map("expira_reset_senha")
  dataCriacao       DateTime           @default(now()) @map("data_criacao")
  dataAtualizacao   DateTime           @updatedAt @map("data_atualizacao")

  // Relacionamentos
  classificacoes    ClassificacaoNF[]
  importacoes       Importacao[]
  logsAuditoria     LogAuditoria[]
  alertas           Alerta[]

  @@map("d_usuarios")
}

model Obra {
  id           Int                @id @default(autoincrement())
  codigoObra   String             @unique @map("codigo_obra") @db.VarChar(50)
  nomeObra     String             @map("nome_obra") @db.VarChar(100)
  cidade       String?            @db.VarChar(100)
  centroCusto  String?            @map("centro_custo") @db.VarChar(50)
  status       Boolean            @default(true)
  dataCriacao  DateTime           @default(now()) @map("data_criacao")
  dataAtualizacao DateTime        @updatedAt @map("data_atualizacao")
  idCentroCusto  String?          @map("id_centro_custo") @db.VarChar(50)
  idUN           String?          @map("id_un") @db.VarChar(50)
  un             String?          @db.VarChar(100)
  descricao      String?          @db.Text
  projeto        String?          @db.VarChar(200)
  local          String?          @db.VarChar(200)
  cliente        String?          @db.VarChar(150)
  gerente        String?          @db.VarChar(120)
  gestor         String?          @db.VarChar(120)

  // Relacionamentos
  notasFiscais      NotaFiscal[]
  classificacoes    ClassificacaoNF[]

  @@map("obras")
}

model Projeto {
  id                Int                @id @default(autoincrement())
  codigo            String             @unique @db.VarChar(50)
  nome              String             @db.VarChar(100)
  descricao         String?            @db.Text
  dataInicio        DateTime?          @map("data_inicio") @db.Date
  dataFim           DateTime?          @map("data_fim") @db.Date
  impactoMensal     Json?              @map("impacto_mensal")
  participantesProjeto Json?           @map("participantes_projeto")
  pessoasCadastradas String?           @map("pessoas_cadastradas") @db.Text
  quantidadePessoasCadastradas Int     @default(0) @map("quantidade_pessoas_cadastradas")
  valorMonetarioPrevisto Decimal       @default(0) @map("valor_monetario_previsto") @db.Decimal(15, 2)
  valorMonetarioRealizado Decimal      @default(0) @map("valor_monetario_realizado") @db.Decimal(15, 2)
  publicoAlvo       String?            @map("publico_alvo") @db.VarChar(200)
  instituicaoId     Int?               @map("instituicao_id")
  imagem                String?        @db.Text
  status            Boolean            @default(true)
  dataCriacao       DateTime           @default(now()) @map("data_criacao")
  dataAtualizacao   DateTime           @updatedAt @map("data_atualizacao")

  // Relacionamentos
  classificacoes    ClassificacaoNF[]
  notasFiscais      NotaFiscal[]
  instituicao       InstituicaoSocial? @relation(fields: [instituicaoId], references: [id])

  @@map("projetos")
  @@index([instituicaoId])
}

model Programa {
  id                Int                @id @default(autoincrement())
  codigo            String             @unique @db.VarChar(50)
  nome              String             @db.VarChar(100)
  descricao         String?            @db.Text
  status            Boolean            @default(true)
  dataCriacao       DateTime           @default(now()) @map("data_criacao")
  dataAtualizacao   DateTime           @updatedAt @map("data_atualizacao")

  // Relacionamentos
  classificacoes    ClassificacaoNF[]
  notasFiscais      NotaFiscal[]

  @@map("programas")
}

model Classificacao {
  id                Int                @id @default(autoincrement())
  codigo            String             @unique @db.VarChar(50)
  nome              String             @db.VarChar(100)
  categoria         String?            @db.VarChar(50)
  status            Boolean            @default(true)
  dataCriacao       DateTime           @default(now()) @map("data_criacao")
  dataAtualizacao   DateTime           @updatedAt @map("data_atualizacao")

  // Relacionamentos
  classificacoes    ClassificacaoNF[]
  notasFiscais      NotaFiscal[]

  @@map("classificacoes")
}

model OrcadoNaoOrcado {
  id                Int                @id @default(autoincrement())
  codigo            String?            @unique @db.VarChar(50)
  nome              String             @unique @db.VarChar(100)
  status            Boolean            @default(true)
  dataCriacao       DateTime           @default(now()) @map("data_criacao")
  dataAtualizacao   DateTime           @updatedAt @map("data_atualizacao")

  // Relacionamentos
  classificacaoContas ClassificacaoConta[]
  notasFiscais        NotaFiscal[]

  @@map("d_orcado_nao_orcado")
  @@index([status])
}

model ClassificacaoConta {
  id                Int                @id @default(autoincrement())
  codigoAcao        Int                @unique @map("codigo_acao")
  nome              String             @db.VarChar(120)
  orcadoNaoOrcadoId Int                @map("orcado_nao_orcado_id")
  status            Boolean            @default(true)
  dataCriacao       DateTime           @default(now()) @map("data_criacao")
  dataAtualizacao   DateTime           @updatedAt @map("data_atualizacao")

  // Relacionamentos
  orcadoNaoOrcado   OrcadoNaoOrcado    @relation(fields: [orcadoNaoOrcadoId], references: [id])
  notasFiscais      NotaFiscal[]

  @@map("classificacao_contas")
  @@index([status])
  @@index([orcadoNaoOrcadoId])
}

model NotaFiscal {
  id                Int                @id @default(autoincrement())
  numeroNF          String             @map("numero_nf") @db.VarChar(50)
  fornecedor        String?            @db.VarChar(100)
  cnpj              String?            @db.VarChar(20)
  valor             Decimal            @db.Decimal(15, 2)
  dataEmissao       DateTime           @map("data_emissao") @db.Date
  obraId            Int?               @map("obra_id")
  actionCode        Int?               @map("action_code")
  classificacaoContaId Int?            @map("classificacao_conta_id")
  orcadoNaoOrcadoId Int?               @map("orcado_nao_orcado_id")
  programaId        Int?               @map("programa_id")
  instituicaoId     Int?               @map("instituicao_id")
  projetoId         Int?               @map("projeto_id")
  classificacaoAttId Int?              @map("classificacao_att_id")
  publicoAlvoId     Int?               @map("publico_alvo_id")
  status            String             @db.VarChar(20)
  origemImportacao  String?            @map("origem_importacao") @db.VarChar(50)
  observacao        String?            @db.Text
  dataCriacao       DateTime           @default(now()) @map("data_criacao")
  dataAtualizacao   DateTime           @updatedAt @map("data_atualizacao")

  // Relacionamentos
  obra                Obra?                @relation(fields: [obraId], references: [id])
  classificacaoConta  ClassificacaoConta?  @relation(fields: [classificacaoContaId], references: [id])
  orcadoNaoOrcado     OrcadoNaoOrcado?     @relation(fields: [orcadoNaoOrcadoId], references: [id])
  programa            Programa?            @relation(fields: [programaId], references: [id])
  instituicao         InstituicaoSocial?   @relation(fields: [instituicaoId], references: [id])
  projeto             Projeto?             @relation(fields: [projetoId], references: [id])
  classificacaoAtt    Classificacao?       @relation(fields: [classificacaoAttId], references: [id])
  publicoAlvo         PublicoAlvo?         @relation(fields: [publicoAlvoId], references: [id])
  classificacoes      ClassificacaoNF[]
  alertas             Alerta[]

  @@map("notas_fiscais")
  @@index([obraId])
  @@index([status])
  @@index([classificacaoContaId])
  @@index([orcadoNaoOrcadoId])
  @@index([programaId])
  @@index([instituicaoId])
  @@index([projetoId])
  @@index([classificacaoAttId])
  @@index([publicoAlvoId])
}

model ClassificacaoNF {
  id                  Int                @id @default(autoincrement())
  notaFiscalId        Int?               @map("nota_fiscal_id")
  projetoId           Int?               @map("projeto_id")
  programaId          Int?               @map("programa_id")
  classificacaoId     Int?               @map("classificacao_id")
  obraId              Int?               @map("obra_id")
  dataClassificacao   DateTime           @default(now()) @map("data_classificacao")
  usuarioId           Int?               @map("usuario_id")
  dataAtualizacao     DateTime           @updatedAt @map("data_atualizacao")

  // Relacionamentos
  notaFiscal          NotaFiscal?        @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)
  projeto             Projeto?           @relation(fields: [projetoId], references: [id])
  programa            Programa?          @relation(fields: [programaId], references: [id])
  classificacao       Classificacao?     @relation(fields: [classificacaoId], references: [id])
  obra                Obra?              @relation(fields: [obraId], references: [id])
  usuario             Usuario?           @relation(fields: [usuarioId], references: [id])

  @@map("classificacoes_nf")
  @@index([notaFiscalId])
  @@index([usuarioId])
}

model Importacao {
  id                Int                @id @default(autoincrement())
  usuarioId         Int?               @map("usuario_id")
  dataImportacao    DateTime           @default(now()) @map("data_importacao")
  arquivo           String?            @db.VarChar(255)
  status            String?            @db.VarChar(20)
  log               String?            @db.Text

  // Relacionamentos
  usuario           Usuario?           @relation(fields: [usuarioId], references: [id])

  @@map("importacoes")
  @@index([usuarioId])
}

model LogAuditoria {
  id                Int                @id @default(autoincrement())
  usuarioId         Int?               @map("usuario_id")
  data              DateTime           @default(now()) @map("data")
  acao              String?            @db.VarChar(100)
  alteracao         String?            @db.Text
  ip                String?            @db.VarChar(50)

  // Relacionamentos
  usuario           Usuario?           @relation(fields: [usuarioId], references: [id])

  @@map("logs_auditoria")
  @@index([usuarioId])
}

model Alerta {
  id                Int                @id @default(autoincrement())
  notaFiscalId      Int?               @map("nota_fiscal_id")
  tipo              String?            @db.VarChar(50)
  mensagem          String?            @db.Text
  status            String?            @db.VarChar(20)
  dataCriacao       DateTime           @default(now()) @map("data_criacao")
  responsavelId     Int?               @map("responsavel_id")

  // Relacionamentos
  notaFiscal        NotaFiscal?        @relation(fields: [notaFiscalId], references: [id])
  responsavel       Usuario?           @relation(fields: [responsavelId], references: [id])

  @@map("alertas")
  @@index([notaFiscalId])
  @@index([responsavelId])
}

model InstituicaoSocial {
  id                      Int                       @id @default(autoincrement())
  instituicao             String                    @db.VarChar(150)
  responsavel             String?                   @db.VarChar(120)
  cep                     String?                   @db.VarChar(20)
  logradouro              String?                   @db.VarChar(180)
  numero                  String?                   @db.VarChar(20)
  complemento             String?                   @db.VarChar(120)
  bairro                  String?                   @db.VarChar(120)
  cidade                  String?                   @db.VarChar(120)
  estado                  String?                   @db.VarChar(10)
  cnpj                    String?                   @db.VarChar(20)
  valorMonetarioPrevisto  Decimal?                  @map("valor_monetario_previsto") @db.Decimal(15, 2)
  prazoPagamento          String?                   @map("prazo_pagamento") @db.VarChar(50)
  dataInicio              DateTime?                 @map("data_inicio") @db.Date
  dataFim                 DateTime?                 @map("data_fim") @db.Date
  descricao               String?                   @db.Text
  historicoFinalidadeOsc  String?                   @map("historico_finalidade_osc") @db.Text
  principaisAcoesProponente String?                 @map("principais_acoes_proponente") @db.Text
  publicoAlvoProponente   String?                   @map("publico_alvo_proponente") @db.Text
  regiaoAlcanceBairros    String?                   @map("regiao_alcance_bairros") @db.Text
  infraestruturaProponente String?                  @map("infraestrutura_proponente") @db.Text
  termoAnexo              String?                   @map("termo_anexo") @db.Text
  liberadoAdmin           Boolean                   @default(false) @map("liberado_admin")
  statusRevisao           String                    @default("PENDENTE") @map("status_revisao") @db.VarChar(30)
  observacoesRevisao      String?                   @map("observacoes_revisao") @db.Text
  revisorEmail            String?                   @map("revisor_email") @db.VarChar(120)
  revisorNome             String?                   @map("revisor_nome") @db.VarChar(120)
  dataRevisao             DateTime?                 @map("data_revisao")
  motivoRejeicao          String?                   @map("motivo_rejeicao") @db.Text
  dataCriacao             DateTime                  @map("data_criacao") @default(now())
  dataAtualizacao         DateTime                  @map("data_atualizacao") @updatedAt

  // Relacionamentos
  responsaveis            ResponsavelInstituicao[]
  responsaveisTecnicos    ResponsavelTecnico[]
  projetos                Projeto[]
  notasFiscais            NotaFiscal[]

  @@map("instituicoes_sociais")
  @@index([instituicao])
  @@index([cidade])
  @@index([dataInicio])
  @@index([statusRevisao])
  @@index([revisorEmail])
  @@index([dataRevisao])
}

model PublicoAlvo {
  id                Int                @id @default(autoincrement())
  nome              String             @db.VarChar(200)
  status            Boolean            @default(true)
  dataCriacao       DateTime           @default(now()) @map("data_criacao")
  dataAtualizacao   DateTime           @updatedAt @map("data_atualizacao")

  // Relacionamentos
  notasFiscais      NotaFiscal[]

  @@map("publicos_alvo")
  @@index([status])
}

model ResponsavelInstituicao {
  id              Int                 @id @default(autoincrement())
  instituicaoId   Int?                @map("instituicao_id")
  representante   String              @db.VarChar(120)
  cpf             String?             @db.VarChar(20)
  rg              String?             @db.VarChar(30)
  orgaoExpedidor  String?             @map("orgao_expedidor") @db.VarChar(50)
  cargo           String?             @db.VarChar(80)
  mandato         String?             @db.VarChar(80)
  endereco        String?             @db.VarChar(180)
  contato         String?             @db.VarChar(30)
  contato2        String?             @db.VarChar(30)
  contato3        String?             @db.VarChar(30)
  email           String?             @db.VarChar(120)
  dataCriacao     DateTime            @default(now()) @map("data_criacao")
  dataAtualizacao DateTime            @default(now()) @updatedAt @map("data_atualizacao")

  // Relacionamentos
  instituicao     InstituicaoSocial?  @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)

  @@index([instituicaoId])
  @@map("responsaveis_instituicao")
}

model ResponsavelTecnico {
  id              Int                 @id @default(autoincrement())
  instituicaoId   Int?                @map("instituicao_id")
  representante   String              @db.VarChar(120)
  cpf             String?             @db.VarChar(20)
  rg              String?             @db.VarChar(30)
  orgaoExpedidor  String?             @map("orgao_expedidor") @db.VarChar(50)
  cargo           String?             @db.VarChar(80)
  mandato         String?             @db.VarChar(80)
  endereco        String?             @db.VarChar(180)
  contato         String?             @db.VarChar(30)
  contato2        String?             @db.VarChar(30)
  contato3        String?             @db.VarChar(30)
  email           String?             @db.VarChar(120)
  dataCriacao     DateTime            @default(now()) @map("data_criacao")
  dataAtualizacao DateTime            @default(now()) @updatedAt @map("data_atualizacao")

  // Relacionamentos
  instituicao     InstituicaoSocial?  @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)

  @@index([instituicaoId])
  @@map("responsaveis_tecnicos")
}


