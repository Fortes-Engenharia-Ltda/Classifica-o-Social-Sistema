# DATABASE (SUPABASE ONLY)
# Copie a URI exata em Supabase > Connect > Session pooler (5432).
# Nao monte manualmente host/regiao/tenant.
DATABASE_URL="COLE_AQUI_A_URI_DA_SESSION_POOLER"
DIRECT_URL="COLE_AQUI_A_URI_DA_SESSION_POOLER"
DB_FALLBACK_ENABLED=false

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# SERVER
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# LOGS
LOG_LEVEL="info"

# FILE UPLOADS
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=52428800

# EXTERNAL INTEGRATIONS
MEGA_API_URL="http://mega-api-url"
SOX_API_URL="http://sox-api-url"
MEGA_API_KEY="your-mega-key"
SOX_API_KEY="your-sox-key"

# SQL SERVER (FORTESDW)
SQLSERVER_HOST="srvfortes01.database.windows.net"
SQLSERVER_PORT=1433
SQLSERVER_DATABASE="FortesDW"
SQLSERVER_USER="usuario_sqlserver"
SQLSERVER_PASSWORD="senha_sqlserver"
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_SERVER_CERTIFICATE=false

# EMAIL (RECUPERACAO DE SENHA)
SMTP_HOST="smtp.seu-provedor.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="usuario_smtp"
SMTP_PASS="senha_smtp"
SMTP_FROM="no-reply@classificacao-social.com"
